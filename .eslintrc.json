{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "globals": {
    "QRCode": "readonly",
    "jsQR": "readonly",
    "Papa": "readonly",
    "sqlFormatter": "readonly",
    "vkbeautify": "readonly",
    "DOMPurify": "readonly",
    "chrome": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "multi-line"],
    "no-var": "error",
    "prefer-const": "warn",
    "no-throw-literal": "error",
    "no-implicit-globals": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-script-url": "error"
  },
  "overrides": [
    {
      "files": ["tests/**/*.mjs"],
      "parserOptions": {
        "sourceType": "module"
      },
      "env": {
        "node": true,
        "browser": false
      }
    }
  ]
}